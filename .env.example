# ===== Embedding Model =====
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1

# ===== Chat LLM =====
LLM_MODEL=qwen/qwen3-30b-a3b
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1

# ===== Reranker =====
RERANKER_MODEL=qwen/qwen3-reranker-8b
RERANKER_API_KEY=your-reranker-api-key
RERANKER_BASE_URL=https://api.openai.com/v1

# ===== Milvus =====
MILVUS_URI=http://localhost:19530
# MILVUS_TOKEN=
MILVUS_COLLECTION=rag_documents
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE
MILVUS_VECTOR_DIM=1024
HNSW_M=16
HNSW_EF_CONSTRUCTION=256
HNSW_EF_SEARCH=128

# ===== MySQL =====
MYSQL_URI=mysql+pymysql://user:password@localhost:3306/rag_memo

# ===== Debug =====
# 开启后终端显示各模块的详细阶段性成果
DEBUG_PIPELINE=true

# ===== RAG =====
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVER_TOP_K=5
